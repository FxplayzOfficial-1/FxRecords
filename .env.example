# FxRecords Configuration
WEBSITE_NAME=FxRecords
WEBSITE_LOGO=https://cdn.discordapp.com/attachments/1518242332586016772/1522614718316150845/file_00000000525871fb89ad6cdeb1478611.png
YOUTUBE_ICON=https://cdn.discordapp.com/attachments/1518242332586016772/1522614698552332420/icon.png

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration (Optional - for backend)
MONGODB_URI=mongodb://localhost:27017/fxrecords

# JWT Configuration (Optional - for backend)
JWT_SECRET=your_jwt_secret_key_here_change_this
JWT_EXPIRE=7d

# Twilio Configuration (SMS Service)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
